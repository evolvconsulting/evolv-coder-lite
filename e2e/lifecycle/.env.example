# evolv-coder-lite lifecycle E2E (.env.example)
#
# This file drives e2e/lifecycle/docker-compose.lifecycle.yml. Copy to
# `e2e/lifecycle/.env` and fill in the secrets — the .env file is gitignored.
#
# Real Bedrock dollars are spent every time the worker container handles a
# turn. Default model is Sonnet 4.6 (~$5-15 per full 12-turn run). For
# bring-up smokes use the Haiku override below.

# --- Bedrock (required) -----------------------------------------------------

# Long-lived Bedrock bearer token (a.k.a. "Bedrock API key"). Generated via
# the AWS console (Bedrock > API keys) or `aws bedrock create-api-key`.
# Claude Code reads this variable name verbatim — DO NOT rename it.
# See: https://code.claude.com/docs/en/amazon-bedrock (Option E).
AWS_BEARER_TOKEN_BEDROCK=

# AWS region where Bedrock is enabled for your account. us-west-2 and
# us-east-1 are common; pick whichever has Sonnet 4.6 access provisioned.
AWS_REGION=us-west-2

# --- Model selection --------------------------------------------------------

# Default for full 12-turn runs. Matches the kit's e2e Dockerfile.
CLAUDE_MODEL=us.anthropic.claude-sonnet-4-6

# Cheaper alternative for first-boot smokes / Dockerfile validation. Swap
# the line above with this one (or just `export CLAUDE_MODEL=...` before
# `docker compose up`) when you don't want to spend Sonnet dollars.
#
#   CLAUDE_MODEL=us.anthropic.claude-haiku-4-5-20251001

# --- fast-mcp-claude (controller bridge) ------------------------------------

# Bearer token the controller (your interactive Claude session on the host)
# uses to authenticate to the worker's MCP server. Generate with:
#   openssl rand -hex 32
MCP_API_KEY=

# Pinned commit of fast-mcp-claude cloned during `docker build`. Bump
# deliberately; do not track `main`.
FMC_REF=f9bcc6e3637e786475f0465b41492819e414a0af
